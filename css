*{
    padding: 0;
    margin: 0;


}

body{
    overflow-x: hidden;


}

article{
    padding: 1rem;

}

section.fondo{
    background-image: url(/lobo.jpg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    height: 90vh;
    margin-bottom: 2rem;

}

header{
    position: absolute;
    text-align: center;
    top: 40%;
    left: 90%;
    transform: translate(-50%, 70%);
    height: 50vh;
    text-transform: uppercase;
    font-weight: bold;
    font-size: 1.5rem;
}
